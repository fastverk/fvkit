common --enable_bzlmod
common --experimental_isolated_extension_usages

# fastverk's private bazel-registry first, fall back to BCR. Module deps
# (rules_rust, protobuf, …) resolve from these.
common --registry=https://raw.githubusercontent.com/fastverk/bazel-registry/main/
common --registry=https://bcr.bazel.build/

# Make bazel's gcc-autodetect (local_config_cc) a no-op stub rather than a hard
# failure on compiler-less images. Pairs with rules_cc_host (MODULE.bazel), which
# supplies the real hermetic clang. This is a repo_env, so a dependency module
# CANNOT carry it — every consumer must set it itself.
common --repo_env=BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=1

common --action_env=HOME

test --test_output=errors
test --test_summary=terse

try-import %workspace%/user.bazelrc
